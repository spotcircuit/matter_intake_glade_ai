# Neon serverless Postgres connection string.
# Create a project at https://console.neon.tech and copy the pooled connection URL.
# `?sslmode=require` is required.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Anthropic API key — used for matter classification and entity extraction.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the model used for classification/extraction.
# Defaults to "claude-sonnet-4-6" in code if unset.
# ANTHROPIC_MODEL=claude-sonnet-4-6
